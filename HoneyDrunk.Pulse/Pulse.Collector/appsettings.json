{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "HoneyDrunk": {
    "Pulse": {
      "Collector": {
        "ServiceName": "Pulse.Collector",
        "Environment": "development",
        "EnableTransportPublishing": true,
        "EnablePostHogSink": false,
        "EnableSentrySink": false,
        "EnableTempoSink": false,
        "EnableLokiSink": false,
        "EnableMimirSink": false,
        "EnableAzureMonitorSink": false
      }
    },
    "OpenTelemetry": {
      "OtlpEndpoint": "http://localhost:4317"
    },
    "PostHog": {
      "ApiKeySecretName": "PostHog--ApiKey",
      "Host": "https://app.posthog.com",
      "Enabled": false
    },
    "Sentry": {
      "DsnSecretName": "Sentry--Dsn",
      "Environment": "development",
      "Enabled": false
    }
  }
}
